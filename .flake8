[flake8]
max-line-length = 88
extend-ignore = E203, E266, E501, W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    migrations/versions,
    .eggs,
    *.egg

per-file-ignores =
    src/migrations/env.py: E402, F401
    src/main.py: F401
    src/core/settings.py: F401
    __init__.py: F401
